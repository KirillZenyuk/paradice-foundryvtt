      "id": "dice-so-nice",
      "type": "module",
      "manifest": "https://gitlab.com/riccisi/foundryvtt-dice-so-nice/raw/master/module/module.json"
    }]
  },
  "styles": [
    "style.css"
  ],
  "scripts": [
    "scripts/archfey.js",
    "scripts/alien.js",
    "scripts/dragon.js",
    "scripts/horned-hammer.js",
    "scripts/master.js",
    "scripts/star-tree.js",
    "scripts/tentacle.js",
    "scripts/trident.js",
    "scripts/water-element.js"
  ],
  "url": "https://github.com/KirillZenyuk/paradice-foundryvtt",
  "manifest": "https://raw.githubusercontent.com/KirillZenyuk/paradice-foundryvtt/master/module.json",
  "download": "https://github.com/KirillZenyuk/paradice-foundryvtt/archive/refs/tags/0.5.1.zip",
  "readme": "https://raw.githubusercontent.com/KirillZenyuk/paradice-foundryvtt/master/README.md"
}
