  "version": "0.5.1",
  "library": "false",
  "authors": [
    {
      "name": "KirillZenyuk",
      "url": "https://github.com/KirillZenyuk"
    }
  ],
  "compatibility": {
    "minimum": 10,
    "verified": 13
  },
  "relationships": {
